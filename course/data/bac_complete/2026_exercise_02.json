    "exercise_number": "التمرين الثالث - موضوع ثان",
    "points": 5,
    "pdf_page": 21
  },
  "title": "متتالية تراجعية مع قراءة بيانية ومتتالية لوغاريتمية",
  "difficulty": "متوسط إلى صعب",
  "axis_tags": [
    "sequence_graphical_representation",
    "seq_monotonicity",
    "mathematical_induction",
    "geometric_sequences",
    "arithmetic_sequences",
    "sequence_limits_convergence_divergence"
  ],
  "statement": {
    "givens": [
      "\\(f(x)=\\dfrac{-6x+2}{2x-3}\\) على \\(]-\\infty,\\frac32[\\).",
      "\\(u_0=0\\) و\\(u_{n+1}=f(u_n)\\).",
      "\\(v_n=\\dfrac{4+2u_n}{1-2u_n}\\).",
      "\\(w_n=\\ln(v_n)\\)."
    ],
    "questions": [
      {
        "id": "q1",
        "number": "1",
        "text": "بقراءة بيانية حدد اتجاه تغير \\(f\\)، وبرر أن \\(f(x)-x\\le0\\) على \\([-2,0]\\)."
      },
      {
        "id": "q2",
        "number": "2",
        "text": "مثّل بيانيًا الحدود \\(u_0,u_1,u_2,u_3\\)، ثم خمن اتجاه تغير المتتالية وتقاربها."
      },
      {
        "id": "q3",
        "number": "3",
        "text": "برهن بالتراجع أن \\(-2<u_n\\le0\\)، ثم حدد اتجاه تغير \\((u_n)\\)."
      },
      {
        "id": "q4",
        "number": "4",
        "text": "أثبت أن \\((v_n)\\) هندسية أساسها \\(\\frac27\\)، اكتب \\(v_n\\)، ثم عبّر عن \\(u_n\\) واحسب النهاية."
      },
      {
        "id": "q5",
        "number": "5",
        "text": "بيّن أن \\((w_n)\\) حسابية وحدد أساسها وحدها الأول، ثم أثبت صيغة مجموع \\(w_0+\\cdots+w_n\\)."
      }
    ]
  },
  "solution": {
    "questions": [
      {
        "question_id": "q1",
        "title": "الدراسة البيانية والجبرية",
        "method": "اشتقاق ومقارنة مع المستقيم",
        "steps": [
          {
            "title": "المشتقة",
            "explanation": "",
            "calculation": "\\(f'(x)=\\dfrac{14}{(2x-3)^2}>0\\)، إذن \\(f\\) متزايدة."
          },
          {
            "title": "المقارنة",
            "explanation": "",
            "calculation": "\\(f(x)-x=\\dfrac{-2(x+2)(x-1)}{2x-3}\\)."
          },
          {
            "title": "الإشارة على [-2,0]",
            "explanation": "على هذا المجال: \\(x+2\\ge0\\)، \\(x-1<0\\)، و\\(2x-3<0\\)، فتكون العبارة \\(\\le0\\)."
          }
        ],
        "final_answer": "\\(f\\) متزايدة و\\(f(x)\\le x\\) على \\([-2,0]\\)."
      },
      {
        "question_id": "q2",
        "title": "الحدود والرسم",
        "method": "تعويض ومخطط سلم",
        "steps": [
          {
            "title": "الحساب",
            "explanation": "",
            "calculation": [
              "\\(u_0=0\\)",
              "\\(u_1=-\\frac23\\)",
              "\\(u_2=-\\frac65\\)",
              "\\(u_3=-\\frac{38}{27}\\)"
            ]
          },
          {
            "title": "التخمين",
            "explanation": "الحدود تنخفض وتقترب من نقطة التثبيت \\(-2\\)."
          }
        ],
        "final_answer": "التخمين: متناقصة ومتقاربة نحو \\(-2\\)."
      },
      {
        "question_id": "q3",
        "title": "الحصر والرتابة",
        "method": "استدلال بالتراجع ثم استعمال f(x)-x",
        "steps": [
          {
            "title": "البداية",
            "explanation": "\\(-2<u_0=0\\le0\\)."
          },
          {
            "title": "الانتقال",
            "explanation": "إذا \\(-2<u_n\\le0\\)، وبما أن \\(f\\) متزايدة:",
            "calculation": "\\(f(-2)<f(u_n)\\le f(0)\\Rightarrow -2<u_{n+1}\\le-\\frac23<0\\)."
          },
          {
            "title": "الرتابة",
            "explanation": "بما أن \\(u_n\\in[-2,0]\\) و\\(f(x)-x\\le0\\):",
            "calculation": "\\(u_{n+1}-u_n=f(u_n)-u_n\\le0\\)."
          }
        ],
        "final_answer": "\\(-2<u_n\\le0\\) و\\((u_n)\\) متناقصة."
      },
      {
        "question_id": "q4",
        "title": "التحويل الهندسي",
        "method": "حساب v_{n+1}",
        "steps": [
          {
            "title": "الحساب",
            "explanation": "",
            "calculation": "\\(v_{n+1}=\\dfrac27v_n\\)."
          },
          {
            "title": "الحد الأول",
            "explanation": "\\(v_0=4\\)."
          },
          {
            "title": "الحد العام",
            "explanation": "",
            "calculation": "\\(v_n=4(\\frac27)^n\\)."
          },
          {
            "title": "استخراج u_n",
            "explanation": "نحل \\(v_n=\\frac{4+2u_n}{1-2u_n}\\):",
            "calculation": "\\(u_n=\\dfrac{v_n-4}{2(v_n+1)}=\\dfrac{4(\\frac27)^n-4}{2[4(\\frac27)^n+1]}\\)."
          },
          {
            "title": "النهاية",
            "explanation": "\\(v_n\\to0\\)، إذن \\(u_n\\to-2\\)."
          }
        ],
        "final_answer": "\\(u_n=\\frac{4(2/7)^n-4}{2(4(2/7)^n+1)}\\)، و\\(\\lim u_n=-2\\)."
      },
      {
        "question_id": "q5",
        "title": "المتتالية اللوغاريتمية",
        "method": "لوغاريتم متتالية هندسية",
        "steps": [
          {
            "title": "العبارة",
            "explanation": "",
            "calculation": "\\(w_n=\\ln4+n\\ln(\\frac27)\\)."
          },
          {
            "title": "الأساس",
            "explanation": "",
            "calculation": "\\(w_{n+1}-w_n=\\ln(\\frac27)=\\ln2-\\ln7\\)."
          },
          {
            "title": "المجموع",
            "explanation": "",
            "calculation": "\\(\\sum_{k=0}^n w_k=(n+1)\\ln4+\\frac{n(n+1)}2(\\ln2-\\ln7)\\)."
          },
          {
            "title": "صيغة مكافئة",
            "explanation": "",
            "calculation": "\\(\\sum_{k=0}^n w_k=\\frac12(n+1)[(\\ln2-\\ln7)n+4\\ln2]\\)."
          }
        ],
        "final_answer": "\\((w_n)\\) حسابية أساسها \\(\\ln2-\\ln7\\)، والمجموع هو الصيغة المطلوبة."
      }
    ]
  },
