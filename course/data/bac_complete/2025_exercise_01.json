  },
  "title": "قراءة بيانية لمتتالية تراجعية وتحويلها إلى هندسية",
  "difficulty": "متوسط",
  "axis_tags": [
    "sequence_graphical_representation",
    "geometric_sequences",
    "sequence_limits_convergence_divergence"
  ],
  "statement": {
    "givens": [
      "\\(f(x)=\\dfrac3{x+2}\\) على \\([-1,+\\infty[\\).",
      "\\(u_0=-1\\) و\\(u_{n+1}=f(u_n)\\).",
      "\\(v_n=\\dfrac{1-u_n}{3+u_n}\\)."
    ],
    "questions": [
      {
        "id": "q1a",
        "number": "1-أ",
        "text": "مثّل بيانيًا الحدود \\(u_0,u_1,u_2,u_3\\) باستعمال منحنى \\(C_f\\) والمستقيم \\(y=x\\)."
      },
      {
        "id": "q1b",
        "number": "1-ب",
        "text": "ضع تخمينًا حول اتجاه تغير \\((u_n)\\) وتقاربها."
      },
      {
        "id": "q2a",
        "number": "2-أ",
        "text": "أثبت أن \\((v_n)\\) هندسية أساسها \\(-\\frac13\\)، ثم اكتب \\(v_n\\) بدلالة \\(n\\)."
      },
      {
        "id": "q2b",
        "number": "2-ب",
        "text": "استنتج عبارة \\(u_n\\) بدلالة \\(n\\)، ثم احسب نهايتها."
      },
      {
        "id": "q3",
        "number": "3",
        "text": "احسب \\(S_n=v_0+\\cdots+v_n\\) و\\(T_n=\\ln|v_0|+\\cdots+\\ln|v_n|\\)."
      }
    ]
  },
  "solution": {
    "questions": [
      {
        "question_id": "q1a",
        "title": "الحدود الأولى والرسم",
        "method": "التعويض وبناء مخطط السلم",
        "steps": [
          {
            "title": "الحساب",
            "explanation": "",
            "calculation": [
              "\\(u_0=-1\\)",
              "\\(u_1=3\\)",
              "\\(u_2=\\frac35\\)",
              "\\(u_3=\\frac{15}{13}\\)"
            ]
          },
          {
            "title": "طريقة الرسم",
            "explanation": "من \\(u_n\\) على محور الفواصل نصعد عموديًا إلى منحنى \\(y=f(x)\\)، ثم نتحرك أفقيًا إلى المستقيم \\(y=x\\). نكرر للحصول على الحد الموالي."
          }
        ],
        "final_answer": "\\(u_0=-1,u_1=3,u_2=\\frac35,u_3=\\frac{15}{13}\\)."
      },
      {
        "question_id": "q1b",
        "title": "التخمين البياني",
        "method": "قراءة مخطط السلم",
        "steps": [
          {
            "title": "الملاحظة",
            "explanation": "الحدود تتناوب حول نقطة التثبيت \\(1\\)، والمسافة عنها تصغر."
          },
          {
            "title": "التخمين",
            "explanation": "المتتالية ليست رتيبة على كامل \\(\\mathbb N\\)، لكنها تتقارب نحو \\(1\\)."
          }
        ],
        "final_answer": "المتتالية متذبذبة حول \\(1\\) ومتقاربة إليه."
      },
      {
        "question_id": "q2a",
        "title": "دراسة المتتالية المساعدة",
        "method": "حساب الحد الموالي",
        "steps": [
          {
            "title": "الحساب",
            "explanation": "",
            "calculation": "\\(v_{n+1}=\\dfrac{1-\\frac3{u_n+2}}{3+\\frac3{u_n+2}}=\\dfrac{u_n-1}{3(u_n+3)}=-\\dfrac13v_n\\)."
          },
          {
            "title": "الحد الأول",
            "explanation": "\\(v_0=\\frac{1-(-1)}{3+(-1)}=1\\)."
          },
          {
            "title": "الحد العام",
            "explanation": "",
            "calculation": "\\(v_n=(-\\frac13)^n\\)."
          }
        ],
        "final_answer": "\\(v_n=(-\\frac13)^n\\)."
      },
      {
        "question_id": "q2b",
        "title": "استخراج u_n والنهاية",
        "method": "حل علاقة كسرية",
        "steps": [
          {
            "title": "الحل",
            "explanation": "من \\(v_n=\\frac{1-u_n}{3+u_n}\\):",
            "calculation": "\\(u_n=\\dfrac{1-3v_n}{1+v_n}=\\dfrac{1-3(-\\frac13)^n}{1+(-\\frac13)^n}\\)."
          },
          {
            "title": "النهاية",
            "explanation": "\\(v_n\\to0\\)، ومنه \\(u_n\\to1\\)."
          }
        ],
        "final_answer": "\\(u_n=\\dfrac{1-3(-\\frac13)^n}{1+(-\\frac13)^n}\\) و\\(\\lim u_n=1\\)."
      },
      {
        "question_id": "q3",
        "title": "المجموعان",
        "method": "مجموع هندسي ومجموع حسابي للوغاريتمات",
        "steps": [
          {
            "title": "حساب S_n",
            "explanation": "",
            "calculation": "\\(S_n=\\dfrac{1-(-\\frac13)^{n+1}}{1+\\frac13}=\\frac34\\left(1-(-\\frac13)^{n+1}\\right)\\)."
          },
          {
            "title": "حساب T_n",
            "explanation": "بما أن \\(|v_k|=(\\frac13)^k\\)، فإن \\(\\ln|v_k|=-k\\ln3\\).",
            "calculation": "\\(T_n=-\\ln3\\sum_{k=0}^n k=-\\frac{n(n+1)}2\\ln3\\)."
          }
        ],
        "final_answer": "\\(S_n=\\frac34(1-(-\\frac13)^{n+1})\\)، و\\(T_n=-\\frac{n(n+1)}2\\ln3\\)."
      }
    ]
  },
