        "lesson_rule_used": "في العلاقة \\(u_{n+2}\\)، نحصل على \\(u_2\\) بوضع \\(n=0\\). وفي التعريف \\(v_n=u_{n+1}-u_n\\)، نعوض مباشرة بقيمة \\(n\\).",
        "steps": [
          {
            "order": 1,
            "title": "كتابة تعريف \\(v_0\\)",
            "explanation": "لدينا \\(v_n=u_{n+1}-u_n\\). نعوض \\(n=0\\).",
            "calculation": "\\(v_0=u_1-u_0=2-1\\)",
            "result": "\\(v_0=1\\)"
          },
          {
            "order": 2,
            "title": "تحديد ما نحتاجه لحساب \\(v_1\\)",
            "explanation": "عند \\(n=1\\) نحصل على \\(v_1=u_2-u_1\\). القيمة \\(u_2\\) غير معطاة، لذا يجب حسابها.",
            "calculation": "\\(v_1=u_2-u_1\\)",
            "result": "نحتاج أولًا إلى حساب \\(u_2\\)."
          },
          {
            "order": 3,
            "title": "حساب \\(u_2\\)",
            "explanation": "العلاقة هي \\(u_{n+2}=\\frac43u_{n+1}-\\frac13u_n\\). للحصول على \\(u_2\\) نضع \\(n=0\\).",
            "calculation": "\\(u_2=\\frac43u_1-\\frac13u_0=\\frac43\\times2-\\frac13\\times1=\\frac83-\\frac13=\\frac73\\)",
            "result": "\\(u_2=\\frac73\\)"
          },
          {
            "order": 4,
            "title": "حساب \\(v_1\\)",
            "explanation": "نعوض الآن بالقيمتين \\(u_2=\\frac73\\) و\\(u_1=2\\).",
            "calculation": "\\(v_1=\\frac73-2=\\frac73-\\frac63\\)",
            "result": "\\(v_1=\\frac13\\)"
          }
        ],
        "final_answer": "\\(v_0=1\\) و\\(v_1=\\frac13\\).",
        "verification": "بالتعويض المباشر في تعريف \\(v_n\\): الفرق الأول هو \\(2-1=1\\)، والفرق الثاني هو \\(\\frac73-2=\\frac13\\).",
        "common_mistakes": [
