          {
            "order": 3,
            "title": "حساب v_1",
            "explanation": "عند n=1 يكون v_1=u_2-u_1.",
            "calculation": "\\(v_1=\\frac73-2=\\frac73-\\frac63\\)",
            "result": "\\(v_1=\\frac13\\)"
          }
        ],
        "final_answer": "\\(v_0=1\\) و\\(v_1=\\frac13\\).",
        "verification": "بما أن u_2=7/3 أكبر من u_1=2، فإن الفرق v_1 موجب، وهو منسجم مع النتيجة.",
        "common_mistakes": [
          {
