        "detailed_explanation": "لدينا v_n=u_{n+1}-u_n، لذلك نعوض بقيم u المتتالية حسب رتبة الحد المطلوب.",
        "steps": [
          {
            "order": 1,
            "title": "حساب v_0",
            "explanation": "عند n=0 نحصل على v_0=u_1-u_0.",
            "calculation": "\\(v_0=2-1\\)",
            "result": "\\(v_0=1\\)"
          },
          {
            "order": 2,
            "title": "حساب u_2",
            "explanation": "نستعمل العلاقة التراجعية عند n=0.",
            "calculation": "\\(u_2=\\frac43u_1-\\frac13u_0=\\frac43\\times2-\\frac13\\times1=\\frac83-\\frac13\\)",
            "result": "\\(u_2=\\frac73\\)"
