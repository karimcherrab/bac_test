    {
      "id": "2012_ex1_q1b",
      "text": "ب- ضع تخمينا حول اتجاه تغير \\((u_n)\\) وتقاربها.",
      "axis_tags": [
        "seq_monotonicity",
        "sequence_limits"
      ],
      "solution": {
        "strategy": "نقرأ السلوك من الرسم.",
        "steps": [
          {
            "step_number": 1,
            "title": "الاتجاه",
            "explanation": "تظهر كل قيمة أكبر من السابقة، فنخمن أن المتتالية متزايدة."
          },
          {
            "step_number": 2,
            "title": "التقارب",
            "explanation": "تقترب الحدود من فاصلة نقطة التقاطع \\((3,3)\\)."
          }
        ],
        "final_answer": "التخمين: \\((u_n)\\) متزايدة ومتقاربة نحو \\(3\\).",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    },
    {
      "id": "2012_ex1_q2",
      "text": "2) برهن بالتراجع أنه من أجل كل عدد طبيعي \\(n\\): \\(0<u_n<3\\).",
      "axis_tags": [
        "mathematical_induction",
        "seq_bounded"
      ],
      "solution": {
        "strategy": "نطبق التراجع على الحصر المزدوج.",
        "steps": [
          {
            "step_number": 1,
            "title": "التحقق",
            "explanation": "",
            "latex": "0<u_0=1<3"
          },
          {
            "step_number": 2,
            "title": "الفرضية",
            "explanation": "نفترض أن \\(0<u_n<3\\)."
          },
          {
            "step_number": 3,
            "title": "حصر ما تحت الجذر",
            "explanation": "من \\(0<u_n<3\\) نحصل على:",
            "latex": "3<2u_n+3<9"
          },
          {
            "step_number": 4,
            "title": "أخذ الجذر",
            "explanation": "الجذر دالة متزايدة على الموجب.",
            "latex": "\\sqrt3<u_{n+1}=\\sqrt{2u_n+3}<3"
          },
          {
            "step_number": 5,
            "title": "الخاتمة",
            "explanation": "وبالأخص \\(0<u_{n+1}<3\\)، إذن الحصر صحيح لكل \\(n\\)."
          }
        ],
        "final_answer": "\\(\\forall n\\in\\mathbb N,\\ 0<u_n<3\\).",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    },
    {
      "id": "2012_ex1_q3a",
      "text": "3) أ- ادرس اتجاه تغير المتتالية \\((u_n)\\).",
      "axis_tags": [
        "seq_monotonicity"
      ],
      "solution": {
        "strategy": "نقارن \\(u_{n+1}\\) و\\(u_n\\) باستعمال الحصر \\(0<u_n<3\\).",
        "steps": [
          {
            "step_number": 1,
            "title": "حساب الفرق بطريقة المرافق",
            "explanation": "",
            "latex": "u_{n+1}-u_n=\\sqrt{2u_n+3}-u_n"
          },
          {
            "step_number": 2,
            "title": "الضرب في المرافق",
            "explanation": "",
            "latex": "u_{n+1}-u_n=\\frac{2u_n+3-u_n^2}{\\sqrt{2u_n+3}+u_n}"
          },
          {
            "step_number": 3,
            "title": "تحليل البسط",
            "explanation": "",
            "latex": "2u_n+3-u_n^2=(3-u_n)(u_n+1)"
          },
          {
            "step_number": 4,
            "title": "دراسة الإشارة",
            "explanation": "بما أن \\(0<u_n<3\\)، فإن \\(3-u_n>0\\)، و\\(u_n+1>0\\)، والمقام موجب؛ لذلك الفرق موجب."
          },
          {
            "step_number": 5,
            "title": "الاستنتاج",
            "explanation": "إذن \\((u_n)\\) متزايدة تماما."
          }
        ],
        "final_answer": "\\((u_n)\\) متزايدة تماما.",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    },
    {
      "id": "2012_ex1_q3b",
      "text": "ب- استنتج أن المتتالية \\((u_n)\\) متقاربة، ثم احسب \\(\\displaystyle\\lim_{n\\to+\\infty}u_n\\).",
      "axis_tags": [
        "sequence_limits"
      ],
      "solution": {
        "strategy": "نستعمل مبرهنة التقارب الرتيب ثم نمر إلى النهاية في العلاقة.",
        "steps": [
          {
            "step_number": 1,
            "title": "إثبات التقارب",
            "explanation": "المتتالية متزايدة ومحدودة من الأعلى بالعدد \\(3\\)، إذن هي متقاربة."
          },
          {
            "step_number": 2,
            "title": "فرض النهاية",
            "explanation": "لنفرض أن نهايتها \\(\\ell\\). بما أن الجذر مستمر:",
            "latex": "\\ell=\\sqrt{2\\ell+3}"
          },
          {
            "step_number": 3,
            "title": "حل معادلة النهاية",
            "explanation": "نربع الطرفين مع مراعاة \\(\\ell\\ge0\\).",
            "latex": "\\ell^2-2\\ell-3=0\\Rightarrow(\\ell-3)(\\ell+1)=0"
          },
          {
            "step_number": 4,
            "title": "اختيار الحل المقبول",
            "explanation": "لدينا \\(0<u_n<3\\)، لذلك \\(\\ell\\ge0\\)، ومنه \\(\\ell=3\\)."
          }
        ],
        "final_answer": "\\(\\displaystyle\\lim_{n\\to+\\infty}u_n=3\\).",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    }
  ]
