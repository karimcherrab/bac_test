  "statement": "في المستوى المنسوب إلى معلم متعامد ومتجانس مثلنا المستقيمين \\((\\Delta)\\) و\\((D)\\) معادلتيهما على الترتيب: \\[y=x\\quad\\text{و}\\quad y=\\frac12x+\\frac13.\\]",
  "questions": [
    {
      "id": "2010_ex1_q1",
      "text": "1) لتكن المتتالية \\((u_n)\\) المعرفة على مجموعة الأعداد الطبيعية \\(\\mathbb N\\) بـ: \\(u_0=6\\)، ومن أجل كل عدد طبيعي \\(n\\): \\[u_{n+1}=\\frac12u_n+\\frac13.\\]",
      "axis_tags": [
        "seq_definition_notation_methods"
      ],
      "solution": {
        "strategy": "هذا السطر يعرّف المتتالية.",
        "steps": [
          {
            "step_number": 1,
            "title": "قراءة التعريف",
            "explanation": "نبدأ من \\(u_0=6\\)، ثم نطبق الدالة \\(f(x)=\\frac12x+\\frac13\\) في كل مرة."
          }
        ],
        "final_answer": "\\(u_{n+1}=\\frac12u_n+\\frac13\\).",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    },
    {
      "id": "2010_ex1_q1a",
      "text": "أ- انقل الشكل ثم مثل على محور الفواصل الحدود التالية: \\(u_0,u_1,u_2,u_3,u_4\\)، دون حسابها مبرزا خطوط الرسم.",
      "axis_tags": [
        "sequence_graphical_representation"
      ],
      "solution": {
        "strategy": "نستعمل مخطط السلم بين المستقيمين.",
        "steps": [
          {
            "step_number": 1,
            "title": "البداية",
            "explanation": "نضع \\(u_0=6\\) على محور الفواصل."
          },
          {
            "step_number": 2,
            "title": "الانتقال العمودي",
            "explanation": "نصعد إلى المستقيم \\(y=\\frac12x+\\frac13\\) للحصول على \\(u_1\\)."
          },
          {
            "step_number": 3,
            "title": "الانتقال الأفقي",
            "explanation": "ننتقل أفقيا إلى المستقيم \\(y=x\\) لننقل القيمة إلى محور الفواصل."
          },
          {
            "step_number": 4,
            "title": "التكرار",
            "explanation": "نكرر العملية إلى أن نمثل \\(u_2,u_3,u_4\\)."
          }
        ],
        "final_answer": "يظهر من الرسم أن الحدود تتناقص نحو \\(\\frac23\\).",
        "verification": "",
        "common_mistakes": [],
