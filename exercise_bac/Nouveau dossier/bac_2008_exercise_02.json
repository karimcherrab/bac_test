    {
      "id": "2008_ex2_q1c",
      "text": "ج- ضع تخمينا حول اتجاه تغير المتتالية \\((u_n)\\) وتقاربها.",
      "axis_tags": [
        "seq_monotonicity",
        "sequence_limits"
      ],
      "solution": {
        "strategy": "نقرأ سلوك الحدود من مخطط السلم.",
        "steps": [
          {
            "step_number": 1,
            "title": "قراءة الاتجاه",
            "explanation": "كل حد ممثل يقع إلى يمين الحد السابق، لذلك نتوقع أن المتتالية متزايدة."
          },
          {
            "step_number": 2,
            "title": "قراءة التقارب",
            "explanation": "الحدود تقترب من فاصلة نقطة تقاطع المستقيمين، أي من العدد \\(6\\)."
          }
        ],
        "final_answer": "التخمين: \\((u_n)\\) متزايدة ومتقاربة نحو \\(6\\).",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    },
    {
      "id": "2008_ex2_q2a",
      "text": "2- أ- برهن بالتراجع أنه من أجل كل عدد طبيعي \\(n\\): \\(u_n\\le6\\).",
      "axis_tags": [
        "mathematical_induction",
        "seq_bounded"
      ],
      "solution": {
        "strategy": "نطبق التراجع على الخاصية \\(u_n\\le6\\).",
        "steps": [
          {
            "step_number": 1,
            "title": "التحقق",
            "explanation": "لدينا:",
            "latex": "u_0=\\frac52\\le6"
          },
          {
            "step_number": 2,
            "title": "الفرضية",
            "explanation": "نفترض أن \\(u_n\\le6\\)."
          },
          {
            "step_number": 3,
            "title": "الانتقال",
            "explanation": "نضرب المتراجحة في \\(\\frac23>0\\) ثم نضيف \\(2\\).",
            "latex": "u_{n+1}=\\frac23u_n+2\\le\\frac23\\cdot6+2=6"
          },
          {
            "step_number": 4,
            "title": "الخاتمة",
            "explanation": "إذن حسب مبدأ التراجع، \\(u_n\\le6\\) لكل \\(n\\)."
          }
        ],
        "final_answer": "\\(\\forall n\\in\\mathbb N,\\ u_n\\le6\\).",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    },
    {
      "id": "2008_ex2_q2b",
      "text": "ب- تحقق أن \\((u_n)\\) متزايدة.",
      "axis_tags": [
        "seq_monotonicity"
      ],
      "solution": {
        "strategy": "نحسب فرق حدين متتاليين ونستعمل الحصر السابق.",
        "steps": [
          {
            "step_number": 1,
            "title": "حساب الفرق",
            "explanation": "",
            "latex": "u_{n+1}-u_n=\\frac23u_n+2-u_n=2-\\frac13u_n=\\frac{6-u_n}{3}"
          },
          {
            "step_number": 2,
            "title": "الإشارة",
            "explanation": "بما أن \\(u_n\\le6\\)، فإن \\(6-u_n\\ge0\\).",
            "latex": "u_{n+1}-u_n\\ge0"
          },
          {
            "step_number": 3,
            "title": "الاستنتاج",
            "explanation": "إذن المتتالية متزايدة."
          }
        ],
        "final_answer": "\\((u_n)\\) متزايدة.",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    },
    {
      "id": "2008_ex2_q2c",
      "text": "ج- هل \\((u_n)\\) متقاربة؟ برر إجابتك.",
      "axis_tags": [
        "sequence_limits",
        "seq_bounded"
      ],
      "solution": {
        "strategy": "نطبق مبرهنة التقارب الرتيب.",
        "steps": [
          {
            "step_number": 1,
            "title": "الرتابة",
            "explanation": "أثبتنا أن \\((u_n)\\) متزايدة."
          },
          {
            "step_number": 2,
            "title": "الحصر",
            "explanation": "أثبتنا أن \\(u_n\\le6\\)، أي أنها محدودة من الأعلى."
          },
          {
            "step_number": 3,
            "title": "الاستنتاج",
            "explanation": "كل متتالية متزايدة ومحدودة من الأعلى متقاربة."
          }
        ],
        "final_answer": "نعم، \\((u_n)\\) متقاربة.",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    },
    {
      "id": "2008_ex2_q3",
      "text": "3- نضع من أجل كل عدد طبيعي \\(n\\): \\(v_n=u_n-6\\).",
      "axis_tags": [
        "geometric_sequences"
      ],
      "solution": {
        "strategy": "هذا السطر يعرّف المتتالية المساعدة.",
        "steps": [
          {
            "step_number": 1,
            "title": "التعريف",
            "explanation": "سنستعمل \\(v_n=u_n-6\\) لتحويل العلاقة التراجعية إلى علاقة هندسية."
          }
        ],
        "final_answer": "\\(v_n=u_n-6\\).",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    },
    {
      "id": "2008_ex2_q3a",
      "text": "أ- أثبت أن \\((v_n)\\) متتالية هندسية، يطلب تعيين أساسها وحدها الأول.",
      "axis_tags": [
        "geometric_sequences"
      ],
      "solution": {
        "strategy": "نحسب \\(v_{n+1}\\) بدلالة \\(v_n\\).",
        "steps": [
          {
            "step_number": 1,
            "title": "حساب الحد الموالي",
            "explanation": "",
            "latex": "v_{n+1}=u_{n+1}-6=\\frac23u_n+2-6"
          },
          {
            "step_number": 2,
            "title": "التبسيط",
            "explanation": "",
            "latex": "v_{n+1}=\\frac23u_n-4=\\frac23(u_n-6)=\\frac23v_n"
          },
          {
            "step_number": 3,
            "title": "الأساس",
            "explanation": "إذن \\((v_n)\\) هندسية أساسها \\(q=\\frac23\\)."
          },
          {
            "step_number": 4,
            "title": "الحد الأول",
            "explanation": "",
            "latex": "v_0=u_0-6=\\frac52-6=-\\frac72"
          }
        ],
        "final_answer": "\\((v_n)\\) هندسية أساسها \\(\\frac23\\) وحدها الأول \\(v_0=-\\frac72\\).",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    },
    {
      "id": "2008_ex2_q3b",
      "text": "ب- اكتب عبارة \\(u_n\\) بدلالة \\(n\\) ثم استنتج \\(\\displaystyle\\lim_{n\\to+\\infty}u_n\\).",
      "axis_tags": [
        "geometric_sequences",
        "sequence_limits"
      ],
      "solution": {
        "strategy": "نكتب الحد العام لـ\\((v_n)\\)، ثم نرجع إلى \\(u_n\\).",
        "steps": [
          {
            "step_number": 1,
            "title": "الحد العام لـ\\(v_n\\)",
            "explanation": "",
            "latex": "v_n=v_0q^n=-\\frac72\\left(\\frac23\\right)^n"
          },
          {
            "step_number": 2,
            "title": "الرجوع إلى \\(u_n\\)",
            "explanation": "بما أن \\(v_n=u_n-6\\)، فإن:",
            "latex": "u_n=6+v_n=6-\\frac72\\left(\\frac23\\right)^n"
          },
          {
            "step_number": 3,
            "title": "حساب النهاية",
            "explanation": "لأن \\(\\left|\\frac23\\right|<1\\)، فإن \\((\\frac23)^n\\to0\\).",
            "latex": "\\lim_{n\\to+\\infty}u_n=6"
          }
        ],
        "final_answer": "\\(u_n=6-\\dfrac72(\\frac23)^n\\)، و\\(\\displaystyle\\lim u_n=6\\).",
        "verification": "",
        "common_mistakes": [],
        "hints": [],
        "graph_data": null,
        "table_data": null
      }
    }
